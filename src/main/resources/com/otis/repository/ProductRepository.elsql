@NAME(FindByFilters)
    SELECT p.id, p.name, p.company_id AS companyID, c.name AS companyName
    FROM products p
        INNER JOIN products_company pc ON p.id = pc.product_id
        INNER JOIN company c ON c.id = pc.company_id

@NAME(CountByFilters)
    SELECT COUNT(DISTINCT p.id)
    FROM products p
        INNER JOIN products_company pc ON p.id = pc.product_id
        INNER JOIN company c ON c.id = pc.company_id
